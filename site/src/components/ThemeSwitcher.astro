<fieldset
  class="theme-switcher"
  data-theme-toggle
  data-mode="system"
>
  <legend class="theme-switcher-legend">Theme preference</legend>
  <span class="theme-switcher-control">
    <span class="theme-switcher-options">
      <label class="theme-switcher-option theme-switcher-day">
        <input type="radio" name="theme-preference" value="light" data-theme-option />
        <span>DAY</span>
      </label>
      <label class="theme-switcher-option theme-switcher-system">
        <input type="radio" name="theme-preference" value="system" data-theme-option checked />
        <span>SYSTEM</span>
      </label>
      <label class="theme-switcher-option theme-switcher-night">
        <input type="radio" name="theme-preference" value="dark" data-theme-option />
        <span>NIGHT</span>
      </label>
    </span>
    <span class="theme-switcher-bearing" aria-hidden="true">
      <span class="theme-switcher-marker"></span>
    </span>
  </span>
</fieldset>

<script is:inline>
  (() => {
    const root = document.documentElement;
    const control = document.querySelector('[data-theme-toggle]');
    const themeColor = document.querySelector('[data-theme-color]');
    const systemPreference = window.matchMedia('(prefers-color-scheme: dark)');
    const validPreferences = new Set(['light', 'system', 'dark']);

    if (!(control instanceof HTMLFieldSetElement)) return;

    const readStoredPreference = () => {
      try {
        const value = localStorage.getItem('ex1te-theme');
        return validPreferences.has(value) ? value : null;
      } catch {
        return null;
      }
    };

    const resolveTheme = (preference) => preference === 'system'
      ? (systemPreference.matches ? 'dark' : 'light')
      : preference;

    let currentPreference = readStoredPreference() ?? 'system';

    const applyPreference = (preference, persist = false) => {
      if (!validPreferences.has(preference)) return;

      currentPreference = preference;
      const theme = resolveTheme(preference);
      root.dataset.theme = theme;
      root.dataset.themeSource = preference;
      root.style.colorScheme = theme;
      control.dataset.mode = preference;

      control.querySelectorAll('[data-theme-option]').forEach((option) => {
        if (option instanceof HTMLInputElement) option.checked = option.value === preference;
      });

      const color = themeColor?.getAttribute(`data-${theme}-color`);
      if (themeColor && color) themeColor.setAttribute('content', color);

      if (persist) {
        try {
          localStorage.setItem('ex1te-theme', preference);
        } catch {
          // The selected preference still works for the current page.
        }
      }
    };

    applyPreference(currentPreference);

    control.addEventListener('change', (event) => {
      const option = event.target;
      if (!(option instanceof HTMLInputElement) || !option.matches('[data-theme-option]')) return;

      root.classList.add('theme-changing');
      applyPreference(option.value, true);
      window.setTimeout(() => root.classList.remove('theme-changing'), 320);
    });

    systemPreference.addEventListener('change', () => {
      if (currentPreference === 'system') applyPreference('system');
    });
  })();
</script>
